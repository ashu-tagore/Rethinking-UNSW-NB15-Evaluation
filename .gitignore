# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

.cache

.mypy_cache

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checkers
.mypy_cache/
.dmypy.json
.pyright/

# ─── PyTorch / ML artefacts ───────────────────────────────────────────────────
# Keep summary.json, classification_report.json, and visualisation PNGs
# (anything a human wants to read) but exclude large binary checkpoints.
results/*/model.pt
results/*/model_best.pt
results/*/preprocessing.pkl
results/*/scaler.pkl
results/*/*.pth

# Legacy flat model layout
models/*.pt
models/*.pkl
models/*.pth

# ─── Dataset files ────────────────────────────────────────────────────────────
# UNSW-NB15 raw CSVs and official pre-split files are large; download separately.
data/
datasets/
*.csv
*.pcap
*.pcapng

# ─── Preprocessing cache ──────────────────────────────────────────────────────
# MD5-hashed cache generated by data_loader.py — always reproducible, never commit.
.cache/

# ─── Logs & run artefacts ─────────────────────────────────────────────────────
logs/
*.log
runs/
wandb/
mlruns/
lightning_logs/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Node / Frontend tooling ──────────────────────────────────────────────────
node_modules/
.npm/
.yarn/
dist/
.parcel-cache/

# ─── OS ───────────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ─── What to KEEP inside results/ ────────────────────────────────────────────
# Unignore the human-readable outputs so experiment records are tracked.
!results/*/summary.json
!results/*/classification_report.json
!results/*/metrics.json
!results/*/config.json
!results/*/*.png

# ─── Backend runtime artefacts ────────────────────────────────────────────────
*.db
*.sqlite3
*.sqlite

# FastAPI / uvicorn process files
*.pid

uploads/


web/frontend/static/css/tailwind.out.css
web/frontend/static/css/output.css